  "description": "Per-provider scraper chain health: success rate and P95 latency.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 1,
      "panels": [],
      "title": "Scraper chain health",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2, "fillOpacity": 10},
          "min": 0,
          "max": 1,
          "unit": "percentunit"
        }
      },
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 1},
      "id": 2,
      "title": "Success rate by provider (5m)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "sum by (provider) (rate(ratatoskr_scraper_attempts_total{status=\"success\"}[5m])) / sum by (provider) (rate(ratatoskr_scraper_attempts_total[5m]))",
          "legendFormat": "{{provider}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2, "fillOpacity": 10},
          "min": 0,
          "unit": "s"
        }
      },
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 1},
      "id": 3,
      "title": "P95 latency by provider (5m)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "histogram_quantile(0.95, sum by (provider, le) (rate(ratatoskr_scraper_attempt_latency_seconds_bucket[5m])))",
          "legendFormat": "{{provider}} p95",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2, "fillOpacity": 10}
        }
      },
      "gridPos": {"h": 9, "w": 24, "x": 0, "y": 10},
      "id": 4,
      "title": "Attempt rate by provider × status (5m)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "sum by (provider, status) (rate(ratatoskr_scraper_attempts_total[5m]))",
          "legendFormat": "{{provider}} / {{status}}",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
