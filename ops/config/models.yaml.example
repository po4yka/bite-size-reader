# Model configuration for Ratatoskr
#
# Copy this file to config/models.yaml and customize.
# Values here are overridden by environment variables when set.
# API keys stay in .env -- this file contains only model choices and tuning.
#
# Priority: env vars > this file > code defaults

# --- OpenRouter (primary LLM provider) ---
openrouter:
  # Primary model for summarization
  model: "deepseek/deepseek-v4-flash"

  # Fallback chain (tried in order if primary fails)
  fallback_models:
    - "moonshotai/kimi-k2.5"
    - "qwen/qwen3-max"

  # Model for content exceeding long_context_threshold
  long_context_model: "minimax/minimax-m1"

  # Fast model for structured-output fallback attempts
  flash_model: "minimax/minimax-m1"
  flash_fallback_models:
    - "qwen/qwen3.5-plus-02-15"

  # Sampling parameters
  temperature: 0.2
  # top_p: 0.9
  # max_tokens: 8192

  # Structured output
  enable_structured_outputs: true
  structured_output_mode: "json_schema"  # or "json_object"

  # Prompt caching (reduces cost for repeated system prompts)
  # enable_prompt_caching: true
  # prompt_cache_ttl: "ephemeral"           # Google/other explicit-cache providers; "ephemeral" or "1h"
  # prompt_cache_ttl_anthropic: "1h"        # Anthropic-specific TTL; "1h" amortizes well across batched requests

# --- Content-aware model routing (optional) ---
# Routes articles to different models based on content type.
# Disable to use a single model for all content.
model_routing:
  enabled: false

  # Model for general content (blogs, tutorials, news)
  default_model: "deepseek/deepseek-v4-flash"

  # Model for technical/research content (papers, code, deep technical)
  technical_model: "deepseek/deepseek-v4-pro"

  # Model for political/historical/opinion content
  sociopolitical_model: "x-ai/grok-4.20-beta"

  # Model for long documents (>50K chars)
  long_context_model: "qwen/qwen3.5-plus-02-15"

  # Shared fallback chain (used when routing is enabled and no tier-specific list is set)
  fallback_models:
    - "deepseek/deepseek-v4-flash"
    - "qwen/qwen3.5-plus-02-15"
    - "minimax/minimax-m1"

  # Per-tier fallback chains (optional; override shared fallback_models when non-empty)
  # technical_fallback_models:
  #   - "deepseek/deepseek-v4-pro"
  # sociopolitical_fallback_models:
  #   - "x-ai/grok-4.20-beta"
  # default_fallback_models:
  #   - "deepseek/deepseek-v4-flash"

  # Token threshold for long-context model selection (~4 chars per token heuristic)
  long_context_threshold_tokens: 180000

  # Vision model (opt-in; used when has_images=True; no default)
  # vision_model: "google/gemini-2.0-flash"

  # Flash model for short-form content (opt-in; no default)
  # quick_model: "qwen/qwen3.6-flash"
  # quick_threshold_tokens: 500

# --- OpenAI (optional direct provider) ---
# openai:
#   model: "gpt-4o"
#   fallback_models:
#     - "gpt-4o-mini"

