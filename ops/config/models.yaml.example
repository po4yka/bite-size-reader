# Model configuration for Bite-Size Reader
#
# Copy this file to config/models.yaml and customize.
# Values here are overridden by environment variables when set.
# API keys stay in .env -- this file contains only model choices and tuning.
#
# Priority: env vars > this file > code defaults

# --- OpenRouter (primary LLM provider) ---
openrouter:
  # Primary model for summarization
  model: "deepseek/deepseek-v3.2"

  # Fallback chain (tried in order if primary fails)
  fallback_models:
    - "moonshotai/kimi-k2.5"
    - "qwen/qwen3-max"
    - "deepseek/deepseek-r1"

  # Model for content exceeding long_context_threshold
  long_context_model: "google/gemini-3-flash-preview"

  # Fast model for structured-output fallback attempts
  flash_model: "google/gemini-3-flash-preview"
  flash_fallback_models:
    - "anthropic/claude-haiku-4.5"

  # Sampling parameters
  temperature: 0.2
  # top_p: 0.9
  # max_tokens: 8192

  # Structured output
  enable_structured_outputs: true
  structured_output_mode: "json_schema"  # or "json_object"

  # Prompt caching (reduces cost for repeated system prompts)
  # enable_prompt_caching: true
  # prompt_cache_ttl: "ephemeral"  # or "1h"

# --- Content-aware model routing (optional) ---
# Routes articles to different models based on content type.
# Disable to use a single model for all content.
model_routing:
  enabled: false

  # Model for general content (blogs, tutorials, news)
  default_model: "anthropic/claude-sonnet-4.6"

  # Model for technical/research content (papers, code, deep technical)
  technical_model: "google/gemini-3.1-pro-preview"

  # Model for political/historical/opinion content
  sociopolitical_model: "x-ai/grok-4.20-beta"

  # Model for long documents (>50K chars)
  long_context_model: "anthropic/claude-sonnet-4.6"

  # Shared fallback chain (used when routing is enabled)
  fallback_models:
    - "deepseek/deepseek-v3.2"
    - "anthropic/claude-opus-4.6"
    - "openai/gpt-5.4"

  # Character threshold for long-context model selection
  long_context_threshold: 50000

