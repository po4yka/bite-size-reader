# Telegram Bot Configuration
# Get these from https://my.telegram.org/apps
API_ID=your_telegram_api_id
API_HASH=your_telegram_api_hash
BOT_TOKEN=your_bot_token_from_botfather

# Access Control
# Comma-separated list of allowed Telegram user IDs
ALLOWED_USER_IDS=123456789

# Mobile API Client Restrictions (optional)
# Comma-separated list of allowed client application IDs
# Leave empty to allow all clients (backward compatible)
# Example: ALLOWED_CLIENT_IDS=android-app-v1.0,ios-app-v2.0,web-v1
ALLOWED_CLIENT_IDS=

# JWT Secret Key for Mobile API
# Generate with: openssl rand -hex 32
# IMPORTANT: Set to a secure random value in production!
JWT_SECRET_KEY=your-secret-key-change-in-production

# Firecrawl Configuration
# Get API key from https://www.firecrawl.dev/
FIRECRAWL_API_KEY=your_firecrawl_api_key
# Request timeout in seconds (default 90, increased for better reliability with slow pages)
# FIRECRAWL_TIMEOUT_SEC=90
# Wait for JS content to load in milliseconds (default 3000, helps with dynamic pages)
# FIRECRAWL_WAIT_FOR_MS=3000

# Multi-provider scraper chain configuration
# Ordered fallback chain (default): scrapling -> firecrawl -> playwright -> crawlee -> direct_html
SCRAPER_ENABLED=true
SCRAPER_PROFILE=balanced
SCRAPER_BROWSER_ENABLED=true
# Optional hard override to a single provider token (empty = disabled)
SCRAPER_FORCE_PROVIDER=
# Optional CSV list of hosts treated as JS-heavy (applies timeout/wait heuristics)
SCRAPER_JS_HEAVY_HOSTS=
SCRAPER_MIN_CONTENT_LENGTH=400
SCRAPER_PROVIDER_ORDER=["scrapling", "firecrawl", "playwright", "crawlee", "direct_html"]
SCRAPER_SCRAPLING_ENABLED=true
SCRAPER_SCRAPLING_TIMEOUT_SEC=30
SCRAPER_SCRAPLING_STEALTH_FALLBACK=true
FIRECRAWL_SELF_HOSTED_ENABLED=false
FIRECRAWL_SELF_HOSTED_URL=http://firecrawl:3002
FIRECRAWL_SELF_HOSTED_API_KEY=fc-ratatoskr-local
SCRAPER_FIRECRAWL_TIMEOUT_SEC=90
SCRAPER_FIRECRAWL_WAIT_FOR_MS=3000
SCRAPER_FIRECRAWL_MAX_RETRIES=3
SCRAPER_FIRECRAWL_MAX_CONNECTIONS=10
SCRAPER_FIRECRAWL_MAX_KEEPALIVE_CONNECTIONS=5
SCRAPER_FIRECRAWL_KEEPALIVE_EXPIRY=30.0
SCRAPER_FIRECRAWL_MAX_RESPONSE_SIZE_MB=50
SCRAPER_PLAYWRIGHT_ENABLED=true
SCRAPER_PLAYWRIGHT_HEADLESS=true
SCRAPER_PLAYWRIGHT_TIMEOUT_SEC=30
SCRAPER_CRAWLEE_ENABLED=true
SCRAPER_CRAWLEE_TIMEOUT_SEC=45
SCRAPER_CRAWLEE_HEADLESS=true
SCRAPER_CRAWLEE_MAX_RETRIES=2
SCRAPER_DIRECT_HTML_ENABLED=true
SCRAPER_DIRECT_HTML_TIMEOUT_SEC=30
SCRAPER_DIRECT_HTML_MAX_RESPONSE_MB=10

# OpenRouter Configuration
# Get API key from https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key

# Primary model for summarization (DeepSeek V3.2 - most reliable for structured outputs)
# Alternative: qwen/qwen3-max (flagship, powerful but higher structured_output_parse_error rate)
OPENROUTER_MODEL=deepseek/deepseek-v3.2

# Fallback models (comma-separated, tried in order if primary fails)
# 1. Kimi K2.5 - Reasoning with structured thinking traces, 256k context
# 2. Qwen3 Max - Powerful flagship model
# 3. DeepSeek R1 - Advanced reasoning (paid tier)
OPENROUTER_FALLBACK_MODELS=moonshotai/kimi-k2.5,qwen/qwen3-max,deepseek/deepseek-r1

# Long context model for large documents (Kimi K2.5 - paid tier, 256k context + reasoning)
# Alternative: moonshotai/kimi-k2 (standard version without thinking traces)
OPENROUTER_LONG_CONTEXT_MODEL=moonshotai/kimi-k2.5

# Flash models for fast fallbacks (Modern February 2026 models)
# OPENROUTER_FLASH_MODEL - Primary fast model
OPENROUTER_FLASH_MODEL=google/gemini-3-flash
# OPENROUTER_FLASH_FALLBACK_MODELS - comma-separated list of fast fallbacks
OPENROUTER_FLASH_FALLBACK_MODELS=anthropic/claude-4.5-haiku

OPENROUTER_HTTP_REFERER=https://github.com/po4yka/ratatoskr
OPENROUTER_X_TITLE=Ratatoskr

# YouTube Video Download Configuration
# Enable/disable YouTube video download feature
YOUTUBE_DOWNLOAD_ENABLED=true
# Directory to store downloaded videos
YOUTUBE_STORAGE_PATH=/data/videos
# Maximum size per video (MB)
YOUTUBE_MAX_VIDEO_SIZE_MB=500
# Maximum total storage for all videos (GB)
YOUTUBE_MAX_STORAGE_GB=100
# Preferred video quality (1080p, 720p, 480p, etc.)
YOUTUBE_PREFERRED_QUALITY=1080p
# Preferred subtitle/transcript languages (comma-separated)
YOUTUBE_SUBTITLE_LANGUAGES=en,ru
# Enable automatic cleanup of old videos
YOUTUBE_AUTO_CLEANUP_ENABLED=true
# Delete videos older than N days
YOUTUBE_CLEANUP_AFTER_DAYS=30

# Twitter / X Extraction (Optional)
TWITTER_ENABLED=true
TWITTER_PREFER_FIRECRAWL=true
TWITTER_PLAYWRIGHT_ENABLED=false
TWITTER_FORCE_TIER=auto
TWITTER_SCRAPER_PROFILE=inherit
TWITTER_MAX_CONCURRENT_BROWSERS=2
TWITTER_COOKIES_PATH=/data/twitter_cookies.txt
TWITTER_HEADLESS=true
TWITTER_PAGE_TIMEOUT_MS=15000
TWITTER_ARTICLE_REDIRECT_RESOLUTION_ENABLED=true
TWITTER_ARTICLE_RESOLUTION_TIMEOUT_SEC=5
# Optional manual smoke gate for scripts/twitter_article_live_smoke.py
TWITTER_ARTICLE_LIVE_SMOKE_ENABLED=false

# Database Configuration
DB_PATH=/data/ratatoskr.db

# Migration / Rust Summary Contract Backend (Optional)
# rust (required): execute summary contract shaping via Rust
# legacy values (`auto`, `python`) are ignored after fallback decommission
SUMMARY_CONTRACT_BACKEND=rust
# Optional explicit path override for Rust binary
# SUMMARY_CONTRACT_RUST_BIN=/absolute/path/to/ratatoskr-summary-contract

# Migration / M3 Pipeline Runtime Bridge (Optional)
# true (required): execute M3 slices via Rust bridge
# fallback-disabled modes are decommissioned
MIGRATION_SHADOW_MODE_ENABLED=true
MIGRATION_SHADOW_MODE_TIMEOUT_MS=250
# legacy comparison controls are deprecated after M3 runtime-authoritative support
MIGRATION_SHADOW_MODE_SAMPLE_RATE=0.0
MIGRATION_SHADOW_MODE_MAX_DIFFS=8
MIGRATION_SHADOW_MODE_EMIT_MATCH_LOGS=false
# Optional explicit path override for Rust pipeline-shadow binary
# PIPELINE_SHADOW_RUST_BIN=/absolute/path/to/ratatoskr-pipeline-shadow

# Migration / M4 Interface Router (Optional)
# rust (required): execute route/command resolution via Rust
# legacy values (`canary`, `python`) are decommissioned
MIGRATION_INTERFACE_BACKEND=rust
MIGRATION_INTERFACE_TIMEOUT_MS=150
# Optional explicit path override for Rust interface-router binary
# INTERFACE_ROUTER_RUST_BIN=/absolute/path/to/ratatoskr-interface-router

# Migration / M6-S1 Telegram Runtime Route Decisions (Optional)
# Command-route execution is fixed to Rust (`ratatoskr-telegram-runtime`).
# Legacy `MIGRATION_TELEGRAM_RUNTIME_BACKEND` is ignored.
MIGRATION_TELEGRAM_RUNTIME_TIMEOUT_MS=150
# Optional explicit path override for Rust telegram runtime binary
# TELEGRAM_RUNTIME_RUST_BIN=/absolute/path/to/ratatoskr-telegram-runtime

# Migration / M5 Cutover Monitoring (Optional)
# JSONL output for standardized cutover events (used by check_m5_cutover_window.py)
MIGRATION_CUTOVER_EVENTS_FILE=/data/migration_cutover_events.jsonl
# Release window duration used by the M5 checker script
MIGRATION_RELEASE_WINDOW_DAYS=14

# Database Operation Limits
# Timeout for database operations in seconds (prevents indefinite hangs)
DB_OPERATION_TIMEOUT=30.0
# Maximum retries for transient database errors (locked/busy)
DB_MAX_RETRIES=3
# JSON validation limits (security against deeply nested/large payloads)
DB_JSON_MAX_SIZE=10000000
DB_JSON_MAX_DEPTH=20
DB_JSON_MAX_ARRAY_LENGTH=10000
DB_JSON_MAX_DICT_KEYS=1000

# Logging Configuration
LOG_LEVEL=INFO
# Enable verbose payload logging (0/1)
DEBUG_PAYLOADS=0

# Request Timeout (seconds)
REQUEST_TIMEOUT_SEC=60

# Language Preference
# PREFERRED_LANG can be 'auto', 'en', or 'ru'
PREFERRED_LANG=auto

# Concurrency
# Limit simultaneous external calls (Firecrawl/OpenRouter)
MAX_CONCURRENT_CALLS=4

# Summary Draft/Token Streaming
SUMMARY_STREAMING_ENABLED=true
SUMMARY_STREAMING_MODE=section
SUMMARY_STREAMING_PROVIDER_SCOPE=openrouter

# Telegram Message Limits
# Maximum characters per Telegram message (Telegram limit ~4096, keep safety margin)
TELEGRAM_MAX_MESSAGE_CHARS=3500
# Maximum URL length (RFC 2616 limit)
TELEGRAM_MAX_URL_LENGTH=2048
# Maximum number of URLs in a batch operation
TELEGRAM_MAX_BATCH_URLS=200
# Minimum interval between messages in milliseconds (rate limiting)
TELEGRAM_MIN_MESSAGE_INTERVAL_MS=100
# Telegram draft streaming controls
TELEGRAM_DRAFT_STREAMING_ENABLED=true
TELEGRAM_DRAFT_MIN_INTERVAL_MS=700
TELEGRAM_DRAFT_MIN_DELTA_CHARS=40
TELEGRAM_DRAFT_MAX_CHARS=3500

# Content Processing Limits
# Maximum text length in kilobytes (for URL extraction, regex DoS prevention)
MAX_TEXT_LENGTH_KB=50

# Optional: E2E Testing
# E2E=1

# MCP Server for OpenClaw / AI Agent Integration (Optional)
MCP_ENABLED=false                               # Enable MCP server
MCP_TRANSPORT=stdio                             # Transport: 'stdio' or 'sse'
MCP_HOST=127.0.0.1                              # Bind address for SSE transport
MCP_PORT=8200                                   # Port for SSE transport
MCP_USER_ID=                                    # Recommended for SSE; required unless MCP_ALLOW_UNSCOPED_SSE=true

# Monitoring (Optional)
# Required when using docker-compose.monitoring.yml
GRAFANA_ADMIN_PASSWORD=change-this-grafana-password
